{
  "id": "qbazaar-local-env",
  "name": "QBazaar — Local",
  "values": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "default",
      "description": "Laravel dev server (php artisan serve). Switch to http://localhost:4010 to use the Prism mock instead.",
      "enabled": true
    },
    {
      "key": "api_prefix",
      "value": "/api/v1",
      "type": "default",
      "enabled": true
    },
    {
      "key": "access_token",
      "value": "",
      "type": "secret",
      "description": "Captured automatically by the Login / Register requests via the test script.",
      "enabled": true
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "secret",
      "description": "Captured automatically by the Login / Register requests; rotated by Refresh.",
      "enabled": true
    },
    {
      "key": "user_id",
      "value": "",
      "type": "default",
      "enabled": true
    },
    {
      "key": "test_email",
      "value": "test+postman@qbazaar.qa",
      "type": "default",
      "enabled": true
    },
    {
      "key": "test_phone",
      "value": "+97455123456",
      "type": "default",
      "enabled": true
    },
    {
      "key": "test_password",
      "value": "Str0ng!Pass1",
      "type": "secret",
      "enabled": true
    },
    {
      "key": "test_full_name",
      "value": "Postman Tester",
      "type": "default",
      "enabled": true
    },
    {
      "key": "otp_code",
      "value": "",
      "type": "default",
      "description": "Fill manually after reading storage/logs/laravel.log (Twilio is faked in dev).",
      "enabled": true
    },
    {
      "key": "reset_token",
      "value": "",
      "type": "default",
      "description": "Fill manually from the password-reset email after running forgot-password.",
      "enabled": true
    },
    {
      "key": "verify_email_id",
      "value": "",
      "type": "default",
      "enabled": true
    },
    {
      "key": "verify_email_hash",
      "value": "",
      "type": "default",
      "enabled": true
    },
    {
      "key": "verify_email_signature",
      "value": "",
      "type": "default",
      "enabled": true
    },
    {
      "key": "test_password_new",
      "value": "NewStr0ng!Pass2",
      "type": "secret",
      "description": "Used by PUT /account/password to switch to a new password.",
      "enabled": true
    },
    {
      "key": "session_id",
      "value": "",
      "type": "default",
      "description": "Personal access token id to revoke via DELETE /account/sessions/{id}. Capture from GET /account/sessions.",
      "enabled": true
    },
    {
      "key": "target_user_id",
      "value": "",
      "type": "default",
      "description": "Another user's ULID, used by the Users folder requests (block, unblock, public-profile, ads).",
      "enabled": true
    },
    {
      "key": "ad_id",
      "value": "",
      "type": "default",
      "description": "Captured automatically by Ads › POST /ads. Used by every ad lifecycle request.",
      "enabled": true
    },
    {
      "key": "category_id",
      "value": "",
      "type": "default",
      "description": "Seed a value via Reference › GET /categories/tree, or paste a ULID manually.",
      "enabled": true
    },
    {
      "key": "location_id",
      "value": "",
      "type": "default",
      "description": "Seed a value via Reference › GET /locations/qatar.",
      "enabled": true
    },
    {
      "key": "media_id_a",
      "value": "",
      "type": "default",
      "description": "ULID of an uploaded ad image. Capture from the POST /ads/:ad/images response.",
      "enabled": true
    },
    {
      "key": "media_id_b",
      "value": "",
      "type": "default",
      "description": "Second image ULID used by reorder requests.",
      "enabled": true
    },
    {
      "key": "saved_search_id",
      "value": "",
      "type": "default",
      "description": "Captured automatically by Search › POST /account/saved-searches.",
      "enabled": true
    }
  ],
  "_postman_variable_scope": "environment"
}
