      "description": "Sprint 4 + 5 Wave A — ad CRUD, lifecycle, image uploads, and the seller's own ads list.",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Capture the ad id from create/show responses so subsequent",
              "// requests in the folder can reference {{ad_id}} without a manual edit.",
              "try {",
              "  const json = pm.response.json();",
              "  if (json && json.success && json.data && json.data.id) {",
              "    pm.environment.set('ad_id', json.data.id);",
              "  }",
              "} catch (e) {}"
            ]
          }
        }
      ],
