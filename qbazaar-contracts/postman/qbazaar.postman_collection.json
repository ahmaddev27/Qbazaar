{
  "info": {
    "_postman_id": "qbazaar-api-collection",
    "name": "QBazaar API",
    "description": "Live collection mirroring the contracts in openapi/v1.yaml.\n\n**How to use**\n1. Import this collection and `qbazaar.local.postman_environment.json` into Postman.\n2. Select the `QBazaar — Local` environment.\n3. Run **Auth › Register** or **Auth › Login** — the access + refresh tokens land in env vars automatically (see the request `Tests` tab).\n4. Every subsequent request uses `{{access_token}}` via the collection-level Authorization.\n\nThis file is kept in sync with the OpenAPI spec each time a new endpoint ships (see PLAN.md → Execution Protocol).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{access_token}}", "type": "string" }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Ensure the base_url has no trailing slash",
          "const base = pm.environment.get('base_url') || '';",
          "if (base.endsWith('/')) {",
          "  pm.environment.set('base_url', base.slice(0, -1));",
          "}"
        ]
      }
    }
  ],
