# QBazaar web — local dev env (copy to .env.local)

# In development the app talks to the Prism mock server.
# Once a real backend endpoint exists, change this to http://localhost:8000.
NEXT_PUBLIC_API_URL=http://localhost:4010

# Production target (used by build-time checks / sitemap)
NEXT_PUBLIC_API_URL_PROD=https://api.qbazzar.miete.site

# Reverb (WebSocket) — only needed from Sprint 8 onwards
NEXT_PUBLIC_REVERB_APP_KEY=local-dev-key
NEXT_PUBLIC_REVERB_HOST=localhost
NEXT_PUBLIC_REVERB_PORT=8080
NEXT_PUBLIC_REVERB_SCHEME=http
