includes:
  - vendor/larastan/larastan/extension.neon

parameters:
  level: 8

  paths:
    - app
    - bootstrap/app.php
    - database/factories
    - database/seeders
    - routes
    - tests

  excludePaths:
    # Laravel scaffold configs — env() returns bool|string and the scaffold doesn't cast.
    # We control app behaviour through config/qbazaar.php which IS analysed via app/.
    - config/*
    # Filament uses runtime-generated schemas; analysis adds noise pre-stable.
    - app/Filament/**/*
    # Pest's dynamic $this binding magic in beforeEach/it scopes (e.g. $this->user) is
    # something PHPStan can't track. We rely on Pest's own runtime checks for tests.
    - tests/Pest.php
    - tests/Feature/Auth/*
    - bootstrap/cache/*
    - storage/*
    - vendor/*

  treatPhpDocTypesAsCertain: false
